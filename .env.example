# --- NEXT.JS FRONTEND ENVIRONMENT VARIABLES ---

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_secret_key"

# Canonical public site URL (sitemap, robots, Open Graph absolute links)
# NEXT_PUBLIC_SITE_URL="https://www.yourdomain.com"

# Browser → API base URL (use https://api.yourdomain.com in real production)
# NEXT_PUBLIC_API_URL="http://localhost:8000"

# Server-only: FastAPI origin for middleware / BFF (Docker: http://backend:8000)
# INTERNAL_API_URL="http://127.0.0.1:8000"

# Shared with backend INTERNAL_API_SECRET (middleware by-slug + never expose to browser)
INTERNAL_API_SECRET="change-me-to-a-long-random-string"

# Optional: show demo tier switch buttons in billing UI (dev only; backend also gates)
# NEXT_PUBLIC_ALLOW_DEMO_TIER_SWITCH="true"

# Local Docker / prod-mode preview only. Never set on Vercel.
# CSP_ALLOW_LOCALHOST=true

# Resend
RESEND_API_KEY="re_your_resend_api_key"

#Sentry
SENTRY_AUTH_TOKEN="your_sentry_vertification_key"

# Feature Flag Delivery API (server-only — used by /api/features/evaluate proxy)
# Never prefix with NEXT_PUBLIC_ (must not reach the browser).
# FEATURE_FLAGS_URL="http://127.0.0.1:8002"
# Docker Compose SaaS -> Pulse on host: FEATURE_FLAGS_URL=http://host.docker.internal:8002
# FEATURE_FLAGS_API_KEY="pf_..."
