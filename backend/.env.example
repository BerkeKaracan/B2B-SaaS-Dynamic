# --- FASTAPI BACKEND ENVIRONMENT VARIABLES ---

# Runtime: development | production
# On Render set ENVIRONMENT=production (hides /docs, /redoc, /openapi.json).
# RENDER=true is also treated as production as a safety net.
ENVIRONMENT="development"

# DB Connection (PostgreSQL)
DATABASE_URL="postgresql://kullanici:sifre@localhost:5432/veritabani_adi"

# Supabase 
SUPABASE_URL="https://senin-projen.supabase.co"
SUPABASE_KEY="senin_supabase_servis_anahtarin"
SUPABASE_SERVICE_ROLE_KEY="senin_supabase_service_role_anahtarin"

# Redis
REDIS_URL="redis://localhost:6379"

# Shared secret for middleware by-slug + ops internal endpoints.
# Must match frontend INTERNAL_API_SECRET (Next.js middleware / Docker).
INTERNAL_API_SECRET="change-me-to-a-long-random-string"

# Local/demo only: allow PUT /api/tenants/{id}/tier.
# Requires ENVIRONMENT=development AND this flag. Disabled in production.
# ALLOW_DEMO_TIER_SWITCH="true"

# Optional external Feature Flag Delivery API (separate repo).
# GET {FEATURE_FLAGS_URL}/evaluate?key=&tenant_id=&tier=
# → { "enabled": true|false }
# Authorization: Bearer {FEATURE_FLAGS_API_KEY}
# When unset/unreachable: fallback to tenants.tier (advanced/pro).
# FEATURE_FLAGS_URL="http://127.0.0.1:8002"
# Docker Compose SaaS -> Pulse on host: FEATURE_FLAGS_URL=http://host.docker.internal:8002
# FEATURE_FLAGS_API_KEY="pf_..."